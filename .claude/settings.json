
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q './gradlew.*assembleDebug' && (git diff --quiet || (git add -A && git commit -m \"build: Android debug build\" 2>/dev/null)) || true",
            "statusMessage": "Auto-committing build changes..."
          }
        ]
      }
    ]
  },
 "attribution": {
    "commit": "Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>",
    "pr": ""
  }
}
