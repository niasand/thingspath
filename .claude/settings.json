{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q './gradlew.*assembleDebug' && (git diff --quiet || (git add -A && git commit -m "$(cat <<'EOF'\nbuild: Android debug build\n\n$(git diff --stat)\nEOF\n)" 2>/dev/null)) || true",
            "statusMessage": "Auto-committing build changes..."
          }
        ]
      }
    ]
  }
}
